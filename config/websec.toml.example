# Exemple de Configuration WebSec
# Copiez ce fichier vers websec.toml et personnalisez-le pour votre environnement

[server]
# Adresse et port d'écoute
listen = "[::]:8080"

# URL du serveur web backend (votre application)
backend = "http://127.0.0.1:3000"

# Nombre de threads workers (défaut : nombre de coeurs CPU)
workers = 4

# Optionnel : définir plusieurs listeners (HTTP / HTTPS)
# Quand ce bloc est présent, la configuration ci-dessus sert de valeur par défaut.
#
# Exemple simple (un seul domaine):
# [[server.listeners]]
# listen = "[::]:80"
# backend = "http://127.0.0.1:8080"
#
# [[server.listeners]]
# listen = "[::]:443"
# backend = "http://127.0.0.1:8080"
# [server.listeners.tls]
# cert_file = "/etc/letsencrypt/live/example.com/fullchain.pem"
# key_file = "/etc/letsencrypt/live/example.com/privkey.pem"
#
# Exemple avancé (SNI multi-domaines sur le même port 443):
# [[server.listeners]]
# listen = "[::]:443"
# backend = "http://127.0.0.1:8080"
# [server.listeners.tls]
# # Certificat par défaut/fallback
# cert_file = "/etc/letsencrypt/live/example.com/fullchain.pem"
# key_file = "/etc/letsencrypt/live/example.com/privkey.pem"
#
# # Certificats SNI additionnels (multiples domaines)
# [[server.listeners.tls.sni_certificates]]
# server_name = "example.org"
# cert_file = "/etc/letsencrypt/live/example.org/fullchain.pem"
# key_file = "/etc/letsencrypt/live/example.org/privkey.pem"
#
# [[server.listeners.tls.sni_certificates]]
# server_name = "*.example.net"  # Support wildcard
# cert_file = "/etc/letsencrypt/live/example.net/fullchain.pem"
# key_file = "/etc/letsencrypt/live/example.net/privkey.pem"

[reputation]
# Score de base pour les nouvelles IPs (0-100, où 100 est excellent)
base_score = 100

# Seuils de décision
threshold_allow = 70        # >= 70: ALLOW (Autoriser)
threshold_ratelimit = 40    # 40-69: RATE_LIMIT (Limiter)
threshold_challenge = 20    # 20-39: CHALLENGE (Proof of Work SHA-256)
threshold_block = 0         # < 20: BLOCK (Bloquer)

# Demi-vie de décroissance exponentielle en heures (récupération du score)
decay_half_life_hours = 24.0

# Bonus de pénalité pour la corrélation (plusieurs familles d'attaques)
correlation_penalty_bonus = 10

# Poids des signaux (Optionnel - valeurs par défaut dans le code si non spécifié)
# Signaux de détection de bots
[reputation.signal_weights]
VulnerabilityScan = 25       # Signatures d'outils + scans de chemins (wp-admin, .env, bursts 404)
SuspiciousUserAgent = 10     # Moyen : curl, wget, python-requests
BotBehaviorPattern = 15      # User-Agent manquant ou profil non humain
AbusiveClient = 15           # Requêtes excessives sans assets

# Signaux Brute Force
FailedLogin = 20                # Multiples échecs de login depuis la même IP
LoginAttemptPattern = 20        # Tentatives rapides séquentielles (password spray)
CredentialStuffing = 25         # Mêmes identifiants depuis plusieurs IPs

# Signaux Flood/DDoS
RequestFlood = 20               # 100+ req en 60s ou burst 50+ req en 2s
ConnectionFlood = 20            # Flood SYN, slowloris (futur)
DistributedAttack = 10          # Attaque coordonnée multi-IP (futur)

# Attaques par Injection
SqlInjectionAttempt = 30        # UNION SELECT, DROP TABLE, OR '1'='1, SLEEP()
XssAttempt = 30                 # <script>, onerror, onload, javascript:
PathTraversalAttempt = 30       # ../, ..\\, %2e%2e%2f
RceAttempt = 50                 # Injection de commande : ;cat, backticks, $()

# Signaux Géographiques
HighRiskCountry = 15            # Requête depuis pays à risque (CN, RU, KP, IR, SY)
ImpossibleTravel = 20           # Changement de pays en moins d'1 heure pour la même IP

# Manipulation de Headers
HeaderInjection = 20            # Injection CRLF, null bytes, headers trop grands
HostHeaderAttack = 20           # Multiples headers Host (cache poisoning)
RefererSpoofing = 10            # TLD Referer suspect (.ru, .cn, .tk, .ml)

[lists]
# Liste Noire : IPs à bloquer immédiatement (score = 0, decision = BLOCK)
# Priorité absolue - surcharge la liste blanche et le scoring
blacklist = [
    # "192.168.1.100",
    # "10.0.0.50",
]

# Liste Blanche : IPs de confiance (score = 100, decision = ALLOW)
# Contourne tous les détecteurs et la logique de scoring
whitelist = [
    # "127.0.0.1",
    # "::1",
]

[storage]
# Type de stockage : "redis" ou "memory" (pour tests/dev)
type = "redis"

# URL de connexion Redis
redis_url = "redis://127.0.0.1:6379"

# Taille du cache L1 (nombre d'IPs en mémoire)
cache_size = 10000

[geolocation]
enabled = true

# Chemin vers la base GeoIP2 (MaxMind GeoLite2-Country.mmdb)
# Télécharger ici : https://dev.maxmind.com/geoip/geolite2-free-geolocation-data
database = "/usr/share/GeoIP/GeoLite2-Country.mmdb"

# Pays à haut risque (Codes ISO 3166-1 alpha-2)
# Les requêtes de ces pays génèrent le signal HighRiskCountry (poids 15)
risk_countries = ["CN", "RU", "KP", "IR", "SY"]

# Fenêtre de détection de voyage impossible (secondes)
# Si le pays change pour une IP dans cette fenêtre -> signal ImpossibleTravel (poids 20)
impossible_travel_window = 3600  # 1 heure

[ratelimit]
# Niveau Normal (score 80-100)
normal_rpm = 1000       # Requêtes par minute
normal_burst = 100      # Burst autorisé

# Niveau Suspect (score 50-79)
suspicious_rpm = 200
suspicious_burst = 20

# Niveau Agressif (score 20-49)
aggressive_rpm = 50
aggressive_burst = 5

# Durée de la fenêtre glissante (secondes)
window_duration_secs = 60

[logging]
# Niveau de log : trace, debug, info, warn, error
level = "info"

# Format de log : "json" ou "pretty" (lisible)
format = "json"

[metrics]
# Activer les métriques Prometheus
enabled = true

# Port HTTP pour les métriques
port = 9090
