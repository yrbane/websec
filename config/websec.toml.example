# WebSec Configuration Example
# Copy to websec.toml and customize for your environment

[server]
# Listen address and port
listen = "0.0.0.0:8080"

# Backend web server URL
backend = "http://127.0.0.1:3000"

# Number of worker threads (default: CPU cores)
workers = 4

[reputation]
# Base score for new IPs (0-100, where 100 is excellent)
base_score = 100

# Decision thresholds
threshold_allow = 70        # >= 70: ALLOW
threshold_ratelimit = 40    # 40-69: RATE_LIMIT
threshold_challenge = 20    # 20-39: CHALLENGE
threshold_block = 0         # < 20: BLOCK

# Exponential decay half-life in hours
decay_half_life_hours = 24.0

# Correlation penalty bonus for multiple different signals
correlation_penalty_bonus = 10

# Signal weights (optional - defaults in code if not specified)
# Bot detection signals
[reputation.signal_weights]
VulnerabilityScan = 25       # High severity: sqlmap, nikto, nmap, acunetix
SuspiciousUserAgent = 10     # Medium: curl, wget, python-requests
BotBehaviorPattern = 15      # Missing UA or non-human profile
AbusiveClient = 15           # Excessive requests without assets

# Brute force signals (US2)
FailedLogin = 20                # Multiple failed login attempts from same IP
LoginAttemptPattern = 20        # Rapid sequential login attempts (password spray)
CredentialStuffing = 25         # Same credentials from multiple IPs

# Injection attacks
SqlInjectionAttempt = 30
XssAttempt = 30
PathTraversalAttempt = 30

[storage]
# Storage type: "redis" or "memory" (for testing)
type = "redis"

# Redis connection URL
redis_url = "redis://127.0.0.1:6379"

# L1 cache size (number of IPs)
cache_size = 10000

[geolocation]
enabled = true

# Path to GeoIP2 database
database = "/usr/share/GeoIP/GeoLite2-City.mmdb"

# Geographic penalties (optional)
[geolocation.penalties]
RU = 15  # Russia
CN = 15  # China  
KP = 30  # North Korea

[ratelimit]
# Normal tier (score 80-100)
normal_rpm = 1000
normal_burst = 100

# Suspicious tier (score 50-79)
suspicious_rpm = 200
suspicious_burst = 20

# Aggressive tier (score 20-49)
aggressive_rpm = 50
aggressive_burst = 5

# Sliding window duration (seconds)
window_duration_secs = 60

[logging]
# Log level: trace, debug, info, warn, error
level = "info"

# Log format: "json" or "pretty"
format = "json"

[metrics]
# Enable Prometheus metrics
enabled = true

# Metrics HTTP port
port = 9090
